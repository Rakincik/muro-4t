# ============================================
# MURO — Production Environment Variables
# ============================================
# Bu dosyayı '.env' olarak kopyala ve değerleri doldur.
# ⚠️ BU DOSYA GIT'E COMMIT EDİLMEMELİ (.gitignore'da)
# ============================================

# --- Domain ---
SITE_URL=https://yourdomain.com
BASE_DOMAIN=yourdomain.com

# --- Database ---
DB_NAME=muro_prod
DB_USER=muro_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- JWT ---
JWT_SECRET=CHANGE_ME_MIN_64_CHARS_RANDOM_SECRET

# --- BigBlueButton ---
BBB_URL=https://bbb.yourdomain.com/bigbluebutton/api
BBB_SECRET=CHANGE_ME_BBB_SHARED_SECRET
BBB_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# --- Gemini AI (Podcast) ---
GEMINI_API_KEY=

# --- Webhook ---
WEBHOOK_SECRET=CHANGE_ME_STRONG_WEBHOOK_SECRET
